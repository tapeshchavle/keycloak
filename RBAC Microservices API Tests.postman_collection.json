    {
      "name": "HR Service (8083)",
      "item": [
        {
          "name": "Get All Employees (ROLE_HR required)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const statusCode = pm.response.code;",
                  "",
                  "if (statusCode === 200) {",
                  "    pm.test(\"Status code is 200 (user has ROLE_HR)\", function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "",
                  "    pm.test(\"Response is an array of employees\", function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.be.an(\"array\");",
                  "    });",
                  "",
                  "    pm.test(\"Employee records have required fields\", function () {",
                  "        const jsonData = pm.response.json();",
                  "        if (Array.isArray(jsonData) && jsonData.length > 0) {",
                  "            jsonData.forEach(function(emp) {",
                  "                pm.expect(emp).to.have.property(\"username\").or.have.property(\"name\").or.have.property(\"employeeId\");",
                  "            });",
                  "        }",
                  "    });",
                  "} else if (statusCode === 403) {",
                  "    pm.test(\"Access denied - user lacks ROLE_HR (403 Forbidden)\", function () {",
                  "        pm.response.to.have.status(403);",
                  "    });",
                  "",
                  "    pm.test(\"Error response contains forbidden message\", function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property(\"error\");",
                  "        pm.expect(jsonData.error).to.include(\"FORBIDDEN\");",
                  "    });",
                  "",
                  "    pm.test(\"Error message mentions required role\", function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property(\"message\");",
                  "        pm.expect(jsonData.message).to.include(\"role\");",
                  "    });",
                  "}",
                  "",
                  "pm.test(\"Response time is less than 1000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
          ],
