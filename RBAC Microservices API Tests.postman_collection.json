            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// This test depends on which token is being used",
                  "const statusCode = pm.response.code;",
                  "",
                  "if (statusCode === 200 || statusCode === 201) {",
                  "    pm.test(\"Payroll processed successfully (admin token used)\", function () {",
                  "        pm.expect(statusCode).to.be.oneOf([200, 201]);",
                  "    });",
                  "",
                  "    pm.test(\"Response confirms processing\", function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.be.an(\"object\");",
                  "    });",
                  "} else if (statusCode === 403) {",
                  "    pm.test(\"Access denied - user lacks ROLE_ADMIN\", function () {",
                  "        pm.response.to.have.status(403);",
                  "    });",
                  "",
                  "    pm.test(\"Error response contains forbidden message\", function () {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property(\"error\");",
                  "        pm.expect(jsonData.error).to.include(\"FORBIDDEN\");",
                  "    });",
                  "}",
                  "",
                  "pm.test(\"Response time is less than 1000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ]
              }
            }
